{
  "entities": {
    "User": {
      "title": "User",
      "description": "A customer of the agency",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "name": { "type": "string", "description": "Full name" },
        "email": { "type": "string", "format": "email", "description": "Email address" },
        "whatsapp": { "type": "string", "description": "WhatsApp number" },
        "initialDescription": { "type": "string", "description": "Initial website description from registration" },
        "role": { "type": "string", "enum": ["client", "admin"], "description": "User role" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "Project": {
      "title": "Project",
      "description": "A web development project request",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "UID of the customer" },
        "websiteName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Approved"], "description": "Current status of the project" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "websiteName", "email", "description", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data"
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Project requests"
    }
  }
}
